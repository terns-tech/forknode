# Copy to .env.local for local dev. Add the same keys in Vercel → Project → Settings → Environment Variables.

# ─── Appwrite (required) ───────────────────────────────────────────────────
NEXT_PUBLIC_APPWRITE_ENDPOINT=
APPWRITE_PROJECT_ID=

# Server-only — create under Appwrite → API Keys (scopes: databases.write)
APPWRITE_API_KEY=
# Database + collection IDs (defaults match docs/APPWRITE_SETUP.md)
APPWRITE_DATABASE_ID=terns
APPWRITE_APPLICATIONS_COLLECTION_ID=applications

# ─── Optional ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_DISCORD_URL=https://discord.gg/terns
# Slack deprecated — community moved to Discord
NEXT_PUBLIC_SLACK_URL=
